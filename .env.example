# OpenAI API (for embeddings and GPT-4 fallback)
OPENAI_API_KEY=sk-your-key-here

# Model paths
FINETUNED_MODEL_PATH=./models/qwen2.5-3b-v7

# ChromaDB
CHROMADB_PATH=./data/vectorstore

# Pinecone RAG (for production RAG ingestion)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=arabic-teaching
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Embedding Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Optional: LangSmith (for observability)
# LANGSMITH_API_KEY=your-key-here
# LANGSMITH_PROJECT=arabic-teaching

# API
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501
