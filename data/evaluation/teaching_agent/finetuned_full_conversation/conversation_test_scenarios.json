          },
          "expected_behaviors": [
            "explains_rule_clearly",
            "shows_examples",
            "mentions_key_indicator_taa_marbuuta"
          ],
          "user_response": "ready for quiz"
        },
        {
          "turn": 3,
          "mode": "feedback_grammar",
          "input": {
            "mode": "feedback_grammar",
            "question": "Is the word مَدْرَسَة masculine or feminine?",
            "student_answer": "feminine",
            "correct_answer": "feminine",
            "explanation": "مَدْرَسَة ends with ة so it's feminine",
            "current_score": "1/1",
            "is_correct": true
          },
          "expected_behaviors": [
            "praise_present",
            "mentions_score",
            "references_rule"
          ],
          "metrics": {
            "sentiment": 0.8
          },
          "user_response": "next"
        },
        {
          "turn": 4,
          "mode": "feedback_grammar",
          "input": {
            "mode": "feedback_grammar",
            "question": "Is the word مُعَلِّمَة (muʿallima - teacher f) masculine or feminine?",
            "student_answer": "masculine",
            "correct_answer": "feminine",
            "explanation": "مُعَلِّمَة ends with ة so it's feminine. It's the female form of teacher",
            "current_score": "1/2",
            "is_correct": false
          },
          "expected_behaviors": [
            "supportive_correction",
            "explains_with_rule_reference",
            "mentions_score"
          ],
          "metrics": {
            "sentiment": 0.7,
            "has_correction": true
          },
          "user_response": "got it"
        }
      ]
    },
    {
      "test_id": "e2e_off_topic_redirect",
      "description": "Edge case: student goes off-topic during vocab batch, model redirects and offers break",
      "category": "edge_case",
      "turns": [
        {
