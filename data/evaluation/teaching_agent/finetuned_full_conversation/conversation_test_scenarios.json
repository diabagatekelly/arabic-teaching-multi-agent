  "scenarios": [
    {
      "test_id": "e2e_vocab_learning_happy_path",
      "description": "Complete vocab learning flow: lesson start → batch intro → quiz with mixed results",
      "category": "happy_path",
      "turns": [
        {
          "turn": 1,
          "mode": "lesson_start",
          "input": {
            "mode": "lesson_start",
            "lesson_number": 1,
            "vocab_summary": {
              "total_words": 10,
              "topics_preview": ["كِتَاب (book)", "قَلَم (pen)", "مَكْتَب (desk)"]
            },
            "grammar_summary": {
              "topics": ["Feminine Nouns", "Definite Article"],
              "topics_count": 2
            }
          },
          "expected_behaviors": [
            "greets_warmly",
            "presents_vocabulary_count",
            "presents_grammar_topics",
            "offers_3_navigation_choices"
          ],
          "user_response": "vocabulary"
        },
        {
          "turn": 2,
          "mode": "teaching_vocab",
          "input": {
            "mode": "teaching_vocab",
            "lesson_number": 1,
            "batch_number": 1,
            "total_batches": 4,
            "words": [
              {"arabic": "كِتَاب", "transliteration": "kitaab", "english": "book"},
              {"arabic": "قَلَم", "transliteration": "qalam", "english": "pen"},
              {"arabic": "مَكْتَب", "transliteration": "maktab", "english": "desk"}
            ]
          },
          "expected_behaviors": [
            "shows_3_words_with_arabic",
            "mentions_flashcards",
            "offers_quiz_next_all_options"
          ],
          "user_response": "1"
        },
        {
          "turn": 3,
          "mode": "feedback_vocab",
          "input": {
            "mode": "feedback_vocab",
            "word_arabic": "كِتَاب",
            "word_transliteration": "kitaab",
            "english": "book",
            "is_correct": true
          },
          "expected_behaviors": [
            "praise_present",
            "checkmark_or_confirmation",
            "word_mentioned"
          ],
          "metrics": {
            "sentiment": 0.8,
            "has_praise": true
          },
          "user_response": "next word"
        },
        {
          "turn": 4,
          "mode": "feedback_vocab",
          "input": {
            "mode": "feedback_vocab",
            "word_arabic": "مَدْرَسَة",
            "word_transliteration": "madrasa",
            "english": "school",
            "student_answer": "house",
            "is_correct": false
          },
          "expected_behaviors": [
            "supportive_correction",
            "shows_correct_answer",
            "flashcard_suggestion",
            "no_false_praise"
          ],
          "metrics": {
            "sentiment": 0.7,
            "has_correction": true,
            "no_praise_words": true
          },
          "user_response": "ok"
        }
      ]
    },
    {
      "test_id": "e2e_grammar_learning_flow",
      "description": "Grammar learning: lesson start → grammar topic explanation → quiz with results",
      "category": "happy_path",
      "turns": [
        {
          "turn": 1,
          "mode": "lesson_start",
          "input": {
            "mode": "lesson_start",
