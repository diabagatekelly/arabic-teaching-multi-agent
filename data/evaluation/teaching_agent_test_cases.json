{
  "metadata": {
    "version": "3.0",
    "created": "2026-04-13",
    "agent": "Agent 1 - Teaching Agent",
    "total_test_cases": 54,
    "description": "Evaluation dataset for Agent 1 (Teaching Agent) - Tests lesson presentation, vocabulary teaching, grammar explanations, and feedback",
    "modes": [
      "lesson_start",
      "teaching_vocab",
      "teaching_grammar",
      "feedback_vocab",
      "feedback_grammar"
    ],
    "metrics": {
      "sentiment_teaching": {
        "description": "Measures warm, encouraging tone for teaching modes",
        "threshold": 0.6,
        "applies_to": [
          "lesson_start",
          "teaching_vocab",
          "teaching_grammar"
        ]
      },
      "sentiment_feedback": {
        "description": "Measures supportive tone for feedback modes",
        "threshold": 0.8,
        "applies_to": [
          "feedback_vocab",
          "feedback_grammar"
        ]
      },
      "feedback_appropriateness": {
        "description": "Validates feedback matches correctness (praise for correct, supportive correction for incorrect)",
        "applies_to": [
          "feedback_vocab",
          "feedback_grammar"
        ],
        "checks": {
          "correct_answer": "Must contain praise keywords (perfect, correct, excellent, great job, well done) and confirm correctness",
          "incorrect_answer": "Must be supportive (not quite, great effort, keep trying) with correction shown, NO false praise"
        }
      },
      "has_navigation": {
        "description": "Checks if response provides navigation options for student",
        "applies_to": [
          "lesson_start",
          "teaching_vocab",
          "teaching_grammar"
        ],
        "checks": "Response includes numbered options or clear next steps"
      },
      "structure_valid": {
        "description": "Validates proper formatting and structure",
        "applies_to": [
          "teaching_vocab"
        ],
        "checks": "Batched vocabulary (3-4 words at a time), no grammar leakage in vocab mode"
      }
    }
  },
